PORT=3000

# Set this to your Vercel frontend URL (no trailing slash).
# Example: https://toe-game.vercel.app
CLIENT_ORIGINS=https://your-vercel-app.vercel.app

# Keep false for production browser-only usage.
ALLOW_NO_ORIGIN=false

# Trust proxy setting for real client IP extraction when behind Nginx/Apache.
# Common values: loopback, linklocal, uniquelocal, or CIDR list.
TRUST_PROXY=loopback

# Optional hardening limits
MAX_ACTIVE_ROOMS=2000
STALE_ROOM_MS=3600000
MAX_SOCKETS_TOTAL=5000
MAX_SOCKETS_PER_CLIENT=25
MAX_SCORE=999
